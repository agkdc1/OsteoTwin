# =============================================================================
# OsteoTwin Environment Configuration
# Copy to .env and fill in actual values
# =============================================================================

# --- LLM API Keys ---
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# --- Claude Model Selection ---
CLAUDE_MODEL_FAST=claude-sonnet-4-20250514
CLAUDE_MODEL_SMART=claude-sonnet-4-20250514
CLAUDE_MAX_RETRIES=3

# --- Gemini Model Selection ---
GEMINI_MODEL=gemini-2.5-flash

# --- JWT / Auth ---
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
ADMIN_USERNAME=admin
ADMIN_PASSWORD=fetch-from-secret-manager

# --- Inter-Service Auth ---
SIM_API_KEY=change-me-sim-key

# --- Server Binding (change these to avoid port conflicts) ---
# ROBOT4KID uses 8000/8100, so OsteoTwin defaults to 8200/8300
PLAN_HOST=0.0.0.0
PLAN_PORT=8200
SIM_HOST=0.0.0.0
SIM_PORT=8300

# --- Simulation Server URL (must match SIM_PORT above) ---
SIMULATION_SERVER_URL=http://localhost:8300

# --- Neo4j Graph Database ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me

# --- GCP ---
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1

# --- Cloud Run (auto-populated by deploy.sh, not needed for local dev) ---
# SIMULATION_SERVER_URL is auto-set to the Cloud Run URL in production
# PLANNING_API_URL=https://osteotwin-planning-xxxxx.run.app
# SIMULATION_API_URL=https://osteotwin-simulation-xxxxx.run.app
